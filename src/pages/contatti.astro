---
// src/pages/contatti.astro
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const contactMethods = [
{ label: 'Email', value: 'hello@studio.com', href: 'mailto:hello@studio.com' },
{ label: 'Telefono', value: '+39 02 1234 5678', href: 'tel:+390212345678' },
{ label: 'Studio', value: 'Milano, Italia', href: '#' }
];
---

<Layout title="Contatti">
    <div class="pt-32 pb-20 md:pt-40 md:pb-32 container-custom">
        <div class="grid lg:grid-cols-2 gap-20">
            <div>
                <span
                    class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-6 block reveal">Contatti</span>
                <h1
                    class="text-5xl md:text-7xl lg:text-8xl font-black text-white mb-8 tracking-tight leading-none reveal-scale delay-100">
                    Parliamo <br /> di futuro.
                </h1>
                <p class="text-lg md:text-xl text-gray-400 mb-16 max-w-md leading-relaxed reveal delay-200">
                    Siamo sempre alla ricerca di nuove sfide. Scrivici per discutere del tuo prossimo progetto digitale.
                </p>

                <div class="grid gap-8">
                    {contactMethods.map((method, index) => (
                    <div class={`border-b border-white/10 pb-8 group reveal delay-${(index + 1) * 100 + 200}`}>
                        <span
                            class="text-xs font-mono uppercase text-gray-600 mb-2 block group-hover:text-gray-400 transition-colors">{method.label}</span>
                        <a href={method.href}
                            class="text-2xl md:text-3xl text-white font-bold hover:text-gray-300 transition-colors inline-flex items-center gap-3 group-hover:translate-x-1 transition-transform">
                            {method.value}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" class="opacity-0 group-hover:opacity-100 transition-opacity">
                                <path d="M7 17l9.2-9.2M17 17V7H7" />
                            </svg>
                        </a>
                    </div>
                    ))}
                </div>
            </div>

            <div class="lg:pt-20 reveal-scale delay-300">
                <ContactForm />
            </div>
        </div>
    </div>
</Layout>