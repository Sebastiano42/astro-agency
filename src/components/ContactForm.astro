---
// src/components/ContactForm.astro
interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Contattaci", 
  subtitle = "Risponderemo entro 24h.",
} = Astro.props;
---

<div class="bg-surfaceHighlight/50 backdrop-blur border border-white/5 p-6 md:p-8 rounded-2xl">
  <div class="mb-8">
      <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
      <p class="text-sm text-gray-500 font-mono">{subtitle}</p>
  </div>
  
  <form class="flex flex-col gap-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="space-y-2">
        <label for="nome" class="text-[10px] font-bold uppercase tracking-wider text-gray-500">Nome</label>
        <input type="text" id="nome" name="nome" class="input-dark bg-black/20" placeholder="Nome Cognome" required />
      </div>
      <div class="space-y-2">
        <label for="email" class="text-[10px] font-bold uppercase tracking-wider text-gray-500">Email</label>
        <input type="email" id="email" name="email" class="input-dark bg-black/20" placeholder="tuo@email.com" required />
      </div>
    </div>

    <div class="space-y-2">
      <label for="servizio" class="text-[10px] font-bold uppercase tracking-wider text-gray-500">Interesse</label>
      <select id="servizio" name="servizio" class="input-dark bg-black/20 cursor-pointer appearance-none">
        <option value="" disabled selected class="text-gray-500">Seleziona un servizio</option>
        <option value="design">Design & UI/UX</option>
        <option value="development">Sviluppo Web</option>
        <option value="ecommerce">E-Commerce</option>
        <option value="marketing">Growth & SEO</option>
      </select>
    </div>

    <div class="space-y-2">
      <label for="messaggio" class="text-[10px] font-bold uppercase tracking-wider text-gray-500">Dettagli</label>
      <textarea id="messaggio" name="messaggio" rows="4" class="input-dark bg-black/20 resize-none" placeholder="Raccontaci del tuo progetto..."></textarea>
    </div>

    <label class="flex items-start gap-3 cursor-pointer group mt-2">
      <div class="relative flex items-center">
        <input type="checkbox" required class="peer h-4 w-4 appearance-none border border-gray-600 rounded bg-transparent checked:bg-white checked:border-white transition-all" />
        <svg class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 text-black opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
      <span class="text-xs text-gray-500 font-mono leading-tight group-hover:text-gray-300 transition-colors">Accetto la privacy policy</span>
    </label>

    <button type="submit" class="w-full bg-white text-black font-bold uppercase text-xs tracking-widest py-4 rounded-lg hover:bg-gray-200 transition-colors mt-4">
      Invia Messaggio
    </button>
  </form>
</div>
